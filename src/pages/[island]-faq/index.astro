---
// Route: /[island]-faq/ — FAQ hub for each island
import Base from '../../layouts/Base.astro';
import faqsData from '../../data/faqs.json';

interface FAQ { question: string; island: string; slug: string; answer: string; links: { text: string; href: string }[]; }

export function getStaticPaths() {
  const config = [
    { slug: 'oahu',       label: 'Oahu',       botfLinks: ['/best/snorkeling-oahu/', '/best/luau-oahu/', '/best/helicopter-oahu/'] },
    { slug: 'maui',       label: 'Maui',       botfLinks: ['/best/snorkeling-maui/', '/best/whale-watch-maui/', '/best/helicopter-maui/'] },
    { slug: 'big-island', label: 'Big Island', botfLinks: ['/best/helicopter-big-island/', '/best/snorkeling-big-island/', '/big-island/'] },
    { slug: 'kauai',      label: 'Kauai',      botfLinks: ['/best/helicopter-kauai/', '/best/land-tours-kauai/', '/best/snorkeling-kauai/'] },
  ];
  return config.map(({ slug, label, botfLinks }) => ({
    params: { island: slug },
    props: { slug, label, botfLinks },
  }));
}

const { slug, label, botfLinks } = Astro.props as { slug: string; label: string; botfLinks: string[] };
const faqs = (faqsData as FAQ[]).filter(f => f.island === slug);

const pageTitle = `${label} Tours FAQ — Common Questions Answered (2026)`;
const pageDesc = `${faqs.length} frequently asked questions about ${label} tours, activities, and travel. Specific answers with prices and operator recommendations.`;
---
<Base title={pageTitle} description={pageDesc}>
  <div class="max-w-3xl mx-auto px-4 py-10">

    <nav class="text-xs text-gray-400 mb-6">
      <a href="/" class="hover:text-ocean-600">Home</a> ›
      <a href={`/${slug}/`} class="hover:text-ocean-600">{label}</a> ›
      <span>FAQ</span>
    </nav>

    <h1 class="text-3xl font-bold mb-2">{label} Tours — Frequently Asked Questions</h1>
    <p class="text-gray-500 mb-8">{faqs.length} questions answered with specific prices, operator names, and honest advice.</p>

    <!-- Top BOTF links -->
    <div class="bg-ocean-50 border border-ocean-200 rounded-xl p-5 mb-8 text-sm">
      <div class="font-semibold text-ocean-700 mb-2">Our Top Picks</div>
      <div class="flex flex-wrap gap-2">
        {botfLinks.map(href => (
          <a href={href} class="border border-ocean-300 text-ocean-700 px-3 py-1 rounded-full hover:bg-ocean-100 transition-colors text-xs">
            {href.replace(/^\/best\//, 'Best ').replace(/^\//, '').replace(/-/g, ' ').replace(/\/$/, '').replace(/\b\w/g, c => c.toUpperCase())}
          </a>
        ))}
      </div>
    </div>

    <!-- FAQ list -->
    <section class="space-y-3">
      {faqs.map(faq => (
        <a href={`/${slug}-faq/${faq.slug}/`}
          class="block border border-gray-200 rounded-xl px-5 py-4 hover:border-ocean-300 hover:bg-ocean-50/30 transition-colors group">
          <div class="font-medium text-gray-900 group-hover:text-ocean-700">{faq.question}</div>
          <p class="text-xs text-gray-400 mt-1 line-clamp-1">{faq.answer.slice(0, 100)}…</p>
        </a>
      ))}
    </section>

    <!-- Back to island -->
    <div class="mt-8 pt-6 border-t border-gray-100">
      <a href={`/${slug}/`} class="text-sm text-ocean-700 hover:underline">← All {label} Tours</a>
    </div>

  </div>
</Base>
