---
import Base from '../../layouts/Base.astro';
import { operators, toSlug } from '../../lib/operators';
import { getReviews, getAllReviewTexts, stars } from '../../lib/reviews';

export function getStaticPaths() {
  return operators.map(op => ({
    params: { slug: toSlug(op.name) },
    props: { operator: op },
  }));
}

const { operator } = Astro.props;

// Load review data via typed helper
const reviews = getReviews(operator);
const composite = reviews?.composite ?? null;
const ta = reviews?.platforms?.tripadvisor ?? null;
const google = reviews?.platforms?.google ?? null;
const allReviews = getAllReviewTexts(reviews, 12);
const positiveReviews = allReviews.filter(r => r.rating != null && r.rating >= 4).slice(0, 3);
const negativeReviews = allReviews.filter(r => r.rating != null && r.rating <= 3).slice(0, 2);

// Find comparison pages involving this operator
const compareOps = operators.filter(op =>
  op.id !== operator.id &&
  op.activity === operator.activity &&
  op.islands.some(i => operator.islands.includes(i))
).slice(0, 5);
const hasReviews = !!(ta || google);

const pageTitle = `${operator.name} Reviews — What Reviewers Say (2026)`;
const pageDesc = composite
  ? `${operator.name} rated ${composite}/5 across TripAdvisor and Google. Prices from $${operator.price_low}. ${operator.notes}`
  : `${operator.name} reviews aggregated from TripAdvisor and Google. Prices from $${operator.price_low}. ${operator.notes}`;
---
<Base title={pageTitle} description={pageDesc}>
  <div class="max-w-4xl mx-auto px-4 py-10">

    <!-- TLDR verdict + composite score -->
    <div class="bg-ocean-50 border border-ocean-200 rounded-xl p-6 mb-8">
      <div class="flex items-start justify-between gap-4">
        <div>
          <div class="text-sm font-semibold text-ocean-700 uppercase tracking-wide mb-1">TLDR Verdict</div>
          <p class="text-gray-800">{operator.notes}</p>
          {operator.fareharbor === 'yes' && (
            <a href="#book"
              class="inline-block mt-4 bg-ocean-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-ocean-700 transition-colors">
              Book Now — From ${operator.price_low}
            </a>
          )}
        </div>
        {composite && (
          <div class="text-center shrink-0 bg-white rounded-xl border border-ocean-200 px-5 py-3">
            <div class="text-4xl font-bold text-ocean-700">{composite}</div>
            <div class="text-xs text-gray-500 mt-1">Composite Score</div>
            <div class="text-xs text-gray-400">out of 5.0</div>
          </div>
        )}
      </div>
    </div>

    <h1 class="text-3xl font-bold mb-2">{operator.name} Reviews</h1>
    <!-- Quick Facts strip -->
    <div class="flex flex-wrap gap-x-8 gap-y-3 mb-8 p-4 bg-gray-50 rounded-xl border border-gray-200 text-sm">
      <div><span class="text-gray-400 text-xs uppercase tracking-wide block">Activity</span><span class="font-medium">{operator.activity}</span></div>
      <div><span class="text-gray-400 text-xs uppercase tracking-wide block">Islands</span><span class="font-medium">{operator.islands.join(', ')}</span></div>
      <div><span class="text-gray-400 text-xs uppercase tracking-wide block">Price Range</span><span class="font-medium">${operator.price_low}–${operator.price_high}</span></div>
      <div><span class="text-gray-400 text-xs uppercase tracking-wide block">Online Booking</span><span class="font-medium">{operator.fareharbor === 'yes' ? 'FareHarbor' : 'Via website'}</span></div>
    </div>

    <!-- Review platform scores -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-4">Review Platform Scores</h2>
      {hasReviews && (
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="text-left px-4 py-3 font-medium text-gray-500">Platform</th>
                <th class="text-left px-4 py-3 font-medium text-gray-500">Rating</th>
                <th class="text-left px-4 py-3 font-medium text-gray-500">Reviews</th>
                <th class="text-left px-4 py-3 font-medium text-gray-500">Weight</th>
                <th class="text-left px-4 py-3 font-medium text-gray-500">Link</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {ta && (
                <tr>
                  <td class="px-4 py-3 font-medium">TripAdvisor</td>
                  <td class="px-4 py-3 font-bold text-ocean-700">{ta.rating ?? '-'}</td>
                  <td class="px-4 py-3 text-gray-600">{ta.reviewCount?.toLocaleString() ?? '-'}</td>
                  <td class="px-4 py-3 text-gray-400">50%</td>
                  <td class="px-4 py-3">{ta.url && <a href={ta.url} target="_blank" rel="noopener noreferrer" class="text-ocean-600 hover:underline text-xs">View</a>}</td>
                </tr>
              )}
              {google && (
                <tr class="bg-gray-50">
                  <td class="px-4 py-3 font-medium">Google</td>
                  <td class="px-4 py-3 font-bold text-ocean-700">{google.rating ?? '-'}</td>
                  <td class="px-4 py-3 text-gray-600">{google.reviewCount?.toLocaleString() ?? '-'}</td>
                  <td class="px-4 py-3 text-gray-400">50%</td>
                  <td class="px-4 py-3">{google.url && <a href={google.url} target="_blank" rel="noopener noreferrer" class="text-ocean-600 hover:underline text-xs">View</a>}</td>
                </tr>
              )}
              {composite && (
                <tr class="bg-ocean-50 font-semibold">
                  <td class="px-4 py-3">Composite Score</td>
                  <td class="px-4 py-3 text-ocean-700 font-bold text-lg">{composite}/5</td>
                  <td class="px-4 py-3 text-gray-500 text-xs" colspan="3">TA 50% + Google 50%</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      )}
      {!hasReviews && (
        <div class="border border-dashed border-gray-200 rounded-xl p-8 text-center text-gray-400">
          <div class="text-3xl mb-2">📊</div>
          <p class="text-sm">Review data is being collected.</p>
          <p class="text-xs mt-1">Check back soon — we aggregate from TripAdvisor and Google.</p>
        </div>
      )}
    </section>

    <!-- Pros & Cons — derived from review ratings -->
    {(positiveReviews.length > 0 || negativeReviews.length > 0) && (
      <section class="mb-10">
        <h2 class="text-xl font-semibold mb-4">Pros &amp; Cons</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {positiveReviews.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-green-700 uppercase tracking-wide mb-3">What Guests Love</h3>
              <ul class="space-y-3">
                {positiveReviews.map(r => (
                  <li class="flex gap-3 text-sm text-gray-700">
                    <span class="text-green-500 mt-0.5 shrink-0">✓</span>
                    <p class="leading-relaxed">{r.text.slice(0, 220)}{r.text.length > 220 ? '…' : ''}</p>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {negativeReviews.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-red-700 uppercase tracking-wide mb-3">Common Complaints</h3>
              <ul class="space-y-3">
                {negativeReviews.map(r => (
                  <li class="flex gap-3 text-sm text-gray-700">
                    <span class="text-red-400 mt-0.5 shrink-0">✗</span>
                    <p class="leading-relaxed">{r.text.slice(0, 220)}{r.text.length > 220 ? '…' : ''}</p>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- What Reviewers Say — all reviews -->
    {allReviews.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-semibold mb-4">What Reviewers Say</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {allReviews.map((r) => (
            <div class="border border-gray-100 rounded-xl p-4 bg-gray-50/50">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">{r.source}</span>
                {r.rating && <span class="text-sm text-yellow-500">{stars(r.rating)}</span>}
              </div>
              <p class="text-sm text-gray-700 leading-relaxed">{r.text}</p>
              {(r.author || r.date) && (
                <p class="text-xs text-gray-400 mt-2">
                  {r.author && <span>{r.author}</span>}
                  {r.author && r.date && <span> · </span>}
                  {r.date && <span>{r.date}</span>}
                </p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Pricing -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-4">Pricing</h2>
      <div class="border border-gray-200 rounded-lg overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-left px-4 py-3 font-medium">Tier</th>
              <th class="text-left px-4 py-3 font-medium">Price</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3">Starting from</td>
              <td class="px-4 py-3 font-semibold">${operator.price_low}</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3">Up to</td>
              <td class="px-4 py-3 font-semibold">${operator.price_high}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Book CTA — always show, FareHarbor when approved, operator site as fallback -->
    <section id="book" class="bg-sand-50 border border-sand-200 rounded-xl p-6 mb-10">
      <h2 class="text-xl font-semibold mb-2">Ready to Book?</h2>
      <p class="text-gray-600 mb-4 text-sm">
        {operator.fareharbor === 'yes'
          ? `${operator.name} uses FareHarbor for online booking.`
          : `Book directly through ${operator.name}'s website.`}
      </p>
      <a href={operator.website} target="_blank" rel="noopener noreferrer"
        class="inline-block bg-ocean-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-ocean-700 transition-colors">
        Book {operator.name} →
      </a>
    </section>

    <!-- Compare with similar operators — bidirectional links (ISC-15) -->
    {compareOps.length > 0 && (
      <section class="mb-10">
        <h2 class="text-lg font-semibold mb-3">Compare {operator.name} With</h2>
        <div class="flex flex-wrap gap-2">
          {compareOps.map(op => (
            <a href={`/compare/${toSlug(operator.name)}-vs-${toSlug(op.name)}/`}
              class="text-sm border border-gray-200 rounded-full px-3 py-1.5 hover:border-ocean-400 hover:text-ocean-700 transition-colors">
              {operator.name} vs {op.name}
            </a>
          ))}
          <a href={`/best/${operator.activity.toLowerCase().replace(/\s+/g,'-')}-${operator.islands[0].toLowerCase().replace(/\s+/g,'-')}/`}
            class="text-sm border border-ocean-200 text-ocean-700 rounded-full px-3 py-1.5 hover:bg-ocean-50 transition-colors">
            Best {operator.activity} in {operator.islands[0]} →
          </a>
        </div>
      </section>
    )}

    {reviews?.updatedAt && (
      <p class="text-xs text-gray-400 mt-4">
        Review data last updated: {new Date(reviews.updatedAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
      </p>
    )}
  </div>
</Base>
