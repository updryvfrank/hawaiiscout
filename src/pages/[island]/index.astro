---
// Route: /[island]/ — island hub page
import Base from '../../layouts/Base.astro';
import { operators, toSlug, ACTIVITIES } from '../../lib/operators';

export function getStaticPaths() {
  const islands = [
    { slug: 'oahu',       label: 'Oahu',       description: 'The Gathering Place — luaus, Pearl Harbor, North Shore surf, and helicopter tours.' },
    { slug: 'maui',       label: 'Maui',       description: 'The Valley Isle — Molokini snorkeling, Road to Hana, whale watching, and helicopter tours.' },
    { slug: 'big-island', label: 'Big Island', description: 'The Big Island — volcano tours, manta ray dives, helicopter over lava, and Kona fishing.' },
    { slug: 'kauai',      label: 'Kauai',      description: 'The Garden Isle — Na Pali Coast helicopter, kayaking to Secret Falls, and sunset boat tours.' },
    { slug: 'lanai',      label: 'Lanai',      description: "Secluded island — snorkeling, Hulopo'e Marine Reserve, and day trips from Maui." },
    { slug: 'molokai',   label: 'Molokai',    description: 'The Friendly Isle — off-the-beaten-path Hawaii, Kalaupapa mule ride, and pristine coastline.' },
  ];
  return islands.map(({ slug, label, description }) => ({
    params: { island: slug },
    props: { slug, label, description },
  }));
}

const { slug, label, description } = Astro.props;
const islandName = slug === 'big-island' ? 'Big Island' : label;

const islandOps = operators.filter(op =>
  op.islands.map(i => i.toLowerCase()).includes(islandName.toLowerCase())
);

// Activities with ranked list pages on this island — requires ≥2 operators (same gate as best/[slug].astro)
const activeActivities = ACTIVITIES.filter(activity =>
  islandOps.filter(op => op.activity === activity).length >= 2
);

// Top comparisons: pairs of same-activity operators sharing this island
const comparisons: { a: typeof islandOps[0]; b: typeof islandOps[0] }[] = [];
for (let i = 0; i < islandOps.length && comparisons.length < 6; i++) {
  for (let j = i + 1; j < islandOps.length && comparisons.length < 6; j++) {
    if (islandOps[i].activity === islandOps[j].activity) {
      comparisons.push({ a: islandOps[i], b: islandOps[j] });
    }
  }
}

// No brand in title — Quaid Rule #1
const pageTitle = `Best ${label} Tours — Ranked by Reviews (2026)`;
const pageDesc = `Best ${label} tours ranked by aggregated TripAdvisor and Google reviews. ${description}`;
---
<Base title={pageTitle} description={pageDesc}>
  <div class="max-w-4xl mx-auto px-4 py-10">

    <h1 class="text-3xl font-bold mb-2">Best {label} Tours</h1>
    <p class="text-gray-500 mb-8">{description}</p>

    <!-- Ranked lists by activity -->
    {activeActivities.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-semibold mb-4">Browse by Activity</h2>
        <div class="flex flex-wrap gap-3">
          {activeActivities.map(activity => (
            <a
              href={`/best/${activity.toLowerCase().replace(/\s+/g, '-')}-${slug}/`}
              class="px-4 py-2 bg-ocean-50 border border-ocean-200 rounded-full text-sm text-ocean-700 hover:bg-ocean-100 transition-colors"
            >
              Best {activity}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Top comparisons for this island -->
    {comparisons.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-semibold mb-4">Head-to-Head Comparisons</h2>
        <div class="flex flex-wrap gap-2">
          {comparisons.map(({ a, b }) => (
            <a
              href={`/compare/${toSlug(a.name)}-vs-${toSlug(b.name)}/`}
              class="text-sm border border-gray-200 rounded-full px-3 py-1.5 hover:border-ocean-400 hover:text-ocean-700 transition-colors"
            >
              {a.name} vs {b.name}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- All operators on this island -->
    {islandOps.length > 0 ? (
      <section class="mb-10">
        <h2 class="text-xl font-semibold mb-4">All {label} Operators</h2>
        <div class="space-y-3">
          {islandOps.map(op => (
            <div class="border border-gray-200 rounded-xl p-4 hover:border-ocean-300 transition-colors">
              <div class="flex justify-between items-center gap-4">
                <div>
                  <a href={`/operators/${toSlug(op.name)}/`} class="font-semibold hover:text-ocean-700">
                    {op.name}
                  </a>
                  <span class="text-sm text-gray-400 ml-2">{op.activity} · ${op.price_low}–${op.price_high}</span>
                </div>
                <a href={`/operators/${toSlug(op.name)}/`}
                  class="text-xs border border-ocean-400 text-ocean-700 px-3 py-1 rounded-full hover:bg-ocean-50 shrink-0">
                  Reviews →
                </a>
              </div>
            </div>
          ))}
        </div>
      </section>
    ) : (
      <section class="mb-10">
        <div class="border border-dashed border-gray-200 rounded-xl p-8 text-center text-gray-400">
          <p class="text-sm">Tour operator data for {label} coming soon.</p>
          <p class="text-xs mt-1">Check Maui and Oahu for the largest operator selection.</p>
        </div>
      </section>
    )}

    <!-- FAQ link -->
    <section>
      <h2 class="text-lg font-semibold mb-3">{label} FAQs</h2>
      <a href={`/${slug}-faq/`}
        class="inline-block text-sm border border-ocean-300 text-ocean-700 px-4 py-2 rounded-lg hover:bg-ocean-50 transition-colors">
        Browse all {label} travel questions →
      </a>
    </section>

  </div>
</Base>
