---
import Base from '../../layouts/Base.astro';
import { operators, getOperatorBySlug, toSlug } from '../../lib/operators';

export function getStaticPaths() {
  return operators.map(op => ({
    params: { slug: toSlug(op.name) },
    props: { operator: op },
  }));
}

const { operator } = Astro.props;
const pageTitle = `${operator.name} Reviews — What Reviewers Say (2026)`;
const pageDesc = `${operator.name} reviews aggregated from TripAdvisor, Google & Yelp. Prices from $${operator.price_low}. ${operator.notes}`;
---
<Base title={pageTitle} description={pageDesc}>
  <div class="max-w-4xl mx-auto px-4 py-10">

    <!-- TLDR verdict -->
    <div class="bg-ocean-50 border border-ocean-200 rounded-xl p-6 mb-8">
      <div class="text-sm font-semibold text-ocean-700 uppercase tracking-wide mb-1">TLDR Verdict</div>
      <p class="text-gray-800">{operator.notes}</p>
      {operator.fareharbor === 'yes' && (
        <a
          href="#book"
          class="inline-block mt-4 bg-ocean-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-ocean-700 transition-colors"
        >
          Book Now — From ${operator.price_low}
        </a>
      )}
    </div>

    <!-- Operator details -->
    <h1 class="text-3xl font-bold mb-2">{operator.name} Reviews</h1>
    <p class="text-gray-500 mb-8">
      {operator.activity} · {operator.islands.join(', ')} · ${operator.price_low}–${operator.price_high}
    </p>

    <!-- Review platforms -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-4">Review Platform Scores</h2>
      <div class="grid grid-cols-3 gap-4">
        {operator.review_platforms.map(platform => (
          <div class="border border-gray-200 rounded-lg p-4 text-center">
            <div class="font-semibold text-sm text-gray-500 mb-1">{platform}</div>
            <div class="text-2xl font-bold text-gray-400">–</div>
            <div class="text-xs text-gray-400 mt-1">Data pending</div>
          </div>
        ))}
      </div>
      <p class="text-xs text-gray-400 mt-3">
        * Live scores will populate once the review aggregation API pipeline is active (Phase 1, ISC-4).
      </p>
    </section>

    <!-- Pricing -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-4">Pricing</h2>
      <div class="border border-gray-200 rounded-lg overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-left px-4 py-3 font-medium">Tier</th>
              <th class="text-left px-4 py-3 font-medium">Price</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3">Starting from</td>
              <td class="px-4 py-3 font-semibold">${operator.price_low}</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3">Up to</td>
              <td class="px-4 py-3 font-semibold">${operator.price_high}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Book CTA -->
    {operator.fareharbor === 'yes' && (
      <section id="book" class="bg-sand-50 border border-sand-200 rounded-xl p-6">
        <h2 class="text-xl font-semibold mb-2">Ready to Book?</h2>
        <p class="text-gray-600 mb-4 text-sm">
          {operator.name} uses FareHarbor for booking. Click below to check availability and book.
        </p>
        <a
          href={operator.website}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-ocean-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-ocean-700 transition-colors"
        >
          Book {operator.name} →
        </a>
      </section>
    )}
  </div>
</Base>
