---
// Route: /best/[activity]-[island]/ or /best/cheapest-[activity]-[island]/
import Base from '../../layouts/Base.astro';
import { operators, getOperatorsByActivity, toSlug, ISLANDS, ACTIVITIES } from '../../lib/operators';

export function getStaticPaths() {
  const paths = [];
  const islands = ['oahu', 'maui', 'big-island', 'kauai'];

  for (const activity of ACTIVITIES) {
    const actSlug = activity.toLowerCase().replace(/\s+/g, '-');

    // Best [activity] in [island]
    for (const island of islands) {
      const islandLabel = island.replace('-', ' ');
      paths.push({
        params: { slug: `${actSlug}-${island}` },
        props: { activity, island, islandLabel, type: 'best' },
      });

      // Cheapest [activity] in [island]
      paths.push({
        params: { slug: `cheapest-${actSlug}-${island}` },
        props: { activity, island, islandLabel, type: 'cheapest' },
      });
    }

    // Best [activity] in hawaii (all islands)
    paths.push({
      params: { slug: `${actSlug}-hawaii` },
      props: { activity, island: 'hawaii', islandLabel: 'Hawaii', type: 'best' },
    });
  }
  return paths;
}

const { activity, island, islandLabel, type } = Astro.props;
const matchingOps = operators
  .filter(op => op.activity === activity && (island === 'hawaii' || op.islands.map(i => i.toLowerCase()).includes(island.toLowerCase().replace('-', ' '))))
  .sort((a, b) => type === 'cheapest' ? a.price_low - b.price_low : b.price_high - a.price_high);

const pageTitle = type === 'cheapest'
  ? `Cheapest ${activity} in ${islandLabel} — Prices From $${matchingOps[0]?.price_low ?? '?'} (2026)`
  : `Best ${activity} in ${islandLabel} — Top ${matchingOps.length} Ranked (2026)`;
const pageDesc = `${type === 'cheapest' ? 'Cheapest' : 'Best'} ${activity.toLowerCase()} operators in ${islandLabel}, ranked by aggregated reviews from TripAdvisor, Google & Yelp.`;
---
<Base title={pageTitle} description={pageDesc}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold mb-2">{pageTitle.replace(' (2026)', '')}</h1>
    <p class="text-gray-500 mb-8">{matchingOps.length} operators ranked · Updated 2026</p>

    {matchingOps.length === 0 ? (
      <p class="text-gray-500">No operators found for this combination yet.</p>
    ) : (
      <div class="space-y-6">
        {matchingOps.map((op, i) => (
          <div class="border border-gray-200 rounded-xl p-6 hover:border-ocean-300 transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="text-xs font-bold text-ocean-600 uppercase tracking-wide mb-1">#{i + 1}</div>
                <h2 class="text-xl font-semibold mb-1">
                  <a href={`/operators/${toSlug(op.name)}/`} class="hover:text-ocean-700">
                    {op.name}
                  </a>
                </h2>
                <p class="text-sm text-gray-500 mb-3">{op.islands.join(', ')} · ${op.price_low}–${op.price_high}</p>
                <p class="text-sm text-gray-700">{op.notes}</p>
              </div>
              <div class="text-right shrink-0">
                <div class="text-2xl font-bold text-gray-800">${op.price_low}</div>
                <div class="text-xs text-gray-400">starting</div>
              </div>
            </div>
            <div class="flex gap-3 mt-4">
              <a href={`/operators/${toSlug(op.name)}/`}
                class="text-sm border border-ocean-400 text-ocean-700 px-4 py-1.5 rounded-lg hover:bg-ocean-50 transition-colors">
                Read Review
              </a>
              {op.fareharbor === 'yes' && (
                <a href={op.website} target="_blank" rel="noopener noreferrer"
                  class="text-sm bg-ocean-600 text-white px-4 py-1.5 rounded-lg hover:bg-ocean-700 transition-colors">
                  Book →
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</Base>
