---
// Route: /compare/[operator-a]-vs-[operator-b]/
import Base from '../../layouts/Base.astro';
import { operators, getOperatorBySlug, toSlug } from '../../lib/operators';

export function getStaticPaths() {
  const paths = [];
  // Generate all operator pairs within the same activity
  for (let i = 0; i < operators.length; i++) {
    for (let j = i + 1; j < operators.length; j++) {
      const a = operators[i];
      const b = operators[j];
      // Only compare operators of the same activity on the same island
      if (a.activity === b.activity && a.islands.some(isle => b.islands.includes(isle))) {
        paths.push({
          params: { slug: `${toSlug(a.name)}-vs-${toSlug(b.name)}` },
          props: { opA: a, opB: b },
        });
      }
    }
  }
  return paths;
}

const { opA, opB } = Astro.props;
const sharedIsland = opA.islands.find(i => opB.islands.includes(i)) ?? opA.islands[0];
const pageTitle = `${opA.name} vs ${opB.name} — Which ${opA.activity} Is Better? (2026)`;
const pageDesc = `Compare ${opA.name} and ${opB.name} side-by-side. Prices, reviews, and a clear winner recommendation.`;
---
<Base title={pageTitle} description={pageDesc}>
  <div class="max-w-4xl mx-auto px-4 py-10">

    <h1 class="text-3xl font-bold mb-2">{opA.name} vs {opB.name}</h1>
    <p class="text-gray-500 mb-8">{opA.activity} · {sharedIsland} · Updated 2026</p>

    <!-- Quick verdict -->
    <div class="bg-ocean-50 border border-ocean-200 rounded-xl p-6 mb-10">
      <div class="text-sm font-semibold text-ocean-700 uppercase tracking-wide mb-2">Quick Verdict</div>
      <p class="text-gray-700">
        Comparison data will populate once the review aggregation API pipeline is active.
        Both operators are top-rated {opA.activity.toLowerCase()} providers in {sharedIsland}.
      </p>
    </div>

    <!-- Comparison table (Kemp model — structured, no logos) -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-4">Side-by-Side Comparison</h2>
      <div class="border border-gray-200 rounded-lg overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-500 w-1/3"></th>
              <th class="text-left px-4 py-3 font-semibold">{opA.name}</th>
              <th class="text-left px-4 py-3 font-semibold">{opB.name}</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr>
              <td class="px-4 py-3 text-gray-500">Activity</td>
              <td class="px-4 py-3">{opA.activity}</td>
              <td class="px-4 py-3">{opB.activity}</td>
            </tr>
            <tr class="bg-gray-50/50">
              <td class="px-4 py-3 text-gray-500">Islands</td>
              <td class="px-4 py-3">{opA.islands.join(', ')}</td>
              <td class="px-4 py-3">{opB.islands.join(', ')}</td>
            </tr>
            <tr>
              <td class="px-4 py-3 text-gray-500">Starting Price</td>
              <td class="px-4 py-3 font-semibold">${opA.price_low}</td>
              <td class="px-4 py-3 font-semibold">${opB.price_low}</td>
            </tr>
            <tr class="bg-gray-50/50">
              <td class="px-4 py-3 text-gray-500">Price Range</td>
              <td class="px-4 py-3">${opA.price_low}–${opA.price_high}</td>
              <td class="px-4 py-3">${opB.price_low}–${opB.price_high}</td>
            </tr>
            <tr>
              <td class="px-4 py-3 text-gray-500">Reviews On</td>
              <td class="px-4 py-3">{opA.review_platforms.join(', ')}</td>
              <td class="px-4 py-3">{opB.review_platforms.join(', ')}</td>
            </tr>
            <tr class="bg-gray-50/50">
              <td class="px-4 py-3 text-gray-500">FareHarbor</td>
              <td class="px-4 py-3">{opA.fareharbor === 'yes' ? '✓ Yes' : opA.fareharbor === 'no' ? 'No' : '—'}</td>
              <td class="px-4 py-3">{opB.fareharbor === 'yes' ? '✓ Yes' : opB.fareharbor === 'no' ? 'No' : '—'}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- CTAs for both operators -->
    <div class="grid md:grid-cols-2 gap-4">
      <div class="border border-gray-200 rounded-xl p-5">
        <h3 class="font-semibold mb-1">{opA.name}</h3>
        <p class="text-sm text-gray-500 mb-3">From ${opA.price_low}</p>
        <a href={`/operators/${toSlug(opA.name)}/`}
          class="block text-center border border-ocean-500 text-ocean-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-ocean-50 transition-colors mb-2">
          Read Full Review
        </a>
        {opA.fareharbor === 'yes' && (
          <a href={opA.website} target="_blank" rel="noopener noreferrer"
            class="block text-center bg-ocean-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-ocean-700 transition-colors">
            Book Now →
          </a>
        )}
      </div>
      <div class="border border-gray-200 rounded-xl p-5">
        <h3 class="font-semibold mb-1">{opB.name}</h3>
        <p class="text-sm text-gray-500 mb-3">From ${opB.price_low}</p>
        <a href={`/operators/${toSlug(opB.name)}/`}
          class="block text-center border border-ocean-500 text-ocean-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-ocean-50 transition-colors mb-2">
          Read Full Review
        </a>
        {opB.fareharbor === 'yes' && (
          <a href={opB.website} target="_blank" rel="noopener noreferrer"
            class="block text-center bg-ocean-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-ocean-700 transition-colors">
            Book Now →
          </a>
        )}
      </div>
    </div>
  </div>
</Base>
