---
// Route: /[island]-faq/[question-slug]/
// FAQ pages — 120 words, 2-3 BOTF internal links (Quaid Rule #7: authority fuel)
// No affiliate CTAs — these pages funnel PageRank to BOTF money pages only.
import Base from '../../layouts/Base.astro';
import faqsData from '../../data/faqs.json';

interface FAQ {
  question: string;
  island: string;
  slug: string;
  answer: string;
  links: { text: string; href: string }[];
}

const faqs = faqsData as FAQ[];

export function getStaticPaths() {
  const data = faqsData as FAQ[];
  return data.map(faq => ({
    params: { island: faq.island, slug: faq.slug },
    props: faq,
  }));
}

const { question, island, answer, links } = Astro.props as FAQ;
const islandLabel = { oahu: 'Oahu', maui: 'Maui', 'big-island': 'Big Island', kauai: 'Kauai', lanai: 'Lanai', molokai: 'Molokai' }[island] ?? island;
// SEO title ≤60 chars — truncate long questions at word boundary
const seoTitle = question.length <= 60
  ? question
  : question.slice(0, 57).replace(/\s\S*$/, '') + '…';
---
<Base
  title={seoTitle}
  description={answer.slice(0, 155) + (answer.length > 155 ? '…' : '')}
>
  <div class="max-w-2xl mx-auto px-4 py-10">

    <!-- Breadcrumb -->
    <nav class="text-xs text-gray-400 mb-6">
      <a href="/" class="hover:text-ocean-600">Home</a> ›
      <a href={`/${island}/`} class="hover:text-ocean-600">{islandLabel}</a> ›
      <span>FAQ</span>
    </nav>

    <!-- Title = exact PAA question (no brand — Quaid Rule #1) -->
    <h1 class="text-2xl font-bold mb-6">{question}</h1>

    <p class="text-gray-800 leading-relaxed mb-8">{answer}</p>

    <!-- Our Top Picks — 2-3 BOTF links (authority funnel, Quaid Rule #7) -->
    {links && links.length > 0 && (
      <div class="border-t border-gray-100 pt-6">
        <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Our Top Picks</div>
        <ul class="space-y-2">
          {links.map(link => (
            <li>
              <a href={link.href} class="text-ocean-700 hover:underline text-sm font-medium">
                → {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

  </div>
</Base>
