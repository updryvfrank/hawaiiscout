---
// Route: /compare/[operator-a]-vs-[operator-b]/
import Base from '../../layouts/Base.astro';
import { operators, toSlug } from '../../lib/operators';
import { getReviews, getAllReviewTexts, getWinner, stars } from '../../lib/reviews';

export function getStaticPaths() {
  const paths = [];
  for (let i = 0; i < operators.length; i++) {
    for (let j = i + 1; j < operators.length; j++) {
      const a = operators[i];
      const b = operators[j];
      if (a.activity === b.activity && a.islands.some(isle => b.islands.includes(isle))) {
        paths.push({
          params: { slug: `${toSlug(a.name)}-vs-${toSlug(b.name)}` },
          props: { opA: a, opB: b },
        });
      }
    }
  }
  return paths;
}

const { opA, opB } = Astro.props;
const sharedIsland = opA.islands.find(i => opB.islands.includes(i)) ?? opA.islands[0];

const revA = getReviews(opA);
const revB = getReviews(opB);
const winner = getWinner(revA, revB);

const reviewsA = getAllReviewTexts(revA, 4);
const reviewsB = getAllReviewTexts(revB, 4);

// SEO title — no brand name per Quaid Rule #1
const pageTitle = `${opA.name} vs ${opB.name} — Which ${opA.activity} Is Better? (2026)`;

// Meta desc: 120-155 chars
const pageDesc = winner === 'A'
  ? `${opA.name} vs ${opB.name}: ${opA.name} wins with ${revA?.composite}/5. Compare prices, reviews & ratings side-by-side.`
  : winner === 'B'
  ? `${opA.name} vs ${opB.name}: ${opB.name} wins with ${revB?.composite}/5. Compare prices, reviews & ratings side-by-side.`
  : `${opA.name} vs ${opB.name} — side-by-side ${opA.activity.toLowerCase()} comparison in ${sharedIsland}. Prices, reviews, and verdict.`;
---
<Base title={pageTitle} description={pageDesc}>
  <div class="max-w-4xl mx-auto px-4 py-10">

    <!-- Breadcrumb -->
    <nav class="text-xs text-gray-400 mb-6">
      <a href="/" class="hover:text-ocean-600">Home</a> ›
      <a href={`/${sharedIsland.toLowerCase().replace(' ', '-')}/`} class="hover:text-ocean-600">{sharedIsland}</a> ›
      <span>{opA.activity}</span>
    </nav>

    <h1 class="text-3xl font-bold mb-1">{opA.name} vs {opB.name}</h1>
    <p class="text-gray-500 mb-8">{opA.activity} · {sharedIsland} · Updated 2026</p>

    <!-- TLDR Verdict -->
    <div class={`rounded-xl p-6 mb-10 border ${
      winner === 'A' ? 'bg-green-50 border-green-200' :
      winner === 'B' ? 'bg-ocean-50 border-ocean-200' :
      'bg-gray-50 border-gray-200'
    }`}>
      <div class="text-xs font-bold uppercase tracking-widest mb-2 text-gray-500">TLDR Verdict</div>
      {winner === 'A' && (
        <p class="text-gray-800 font-medium">
          <span class="text-green-700 font-bold">{opA.name}</span> wins with a higher composite score
          ({revA?.composite}/5 vs {revB?.composite ?? '–'}/5), based on aggregated TripAdvisor and Google reviews.
        </p>
      )}
      {winner === 'B' && (
        <p class="text-gray-800 font-medium">
          <span class="text-ocean-700 font-bold">{opB.name}</span> wins with a higher composite score
          ({revB?.composite}/5 vs {revA?.composite ?? '–'}/5), based on aggregated TripAdvisor and Google reviews.
        </p>
      )}
      {winner === 'tie' && (
        <p class="text-gray-800 font-medium">
          It's essentially a <strong>tie</strong> — both score {revA?.composite}/5. Choose based on price,
          availability, or which island location suits you better.
        </p>
      )}
      {!winner && (
        <p class="text-gray-600">
          Both are top-rated {opA.activity.toLowerCase()} operators in {sharedIsland}.
          See the full comparison below.
        </p>
      )}
    </div>

    <!-- Kemp Comparison Table — structured, no logos, no icons -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-4">Side-by-Side Comparison</h2>
      <div class="border border-gray-200 rounded-lg overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-500 w-1/3"></th>
              <th class="text-left px-4 py-3 font-semibold text-base">
                {opA.name}
                {winner === 'A' && <span class="ml-2 text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-normal">Winner</span>}
              </th>
              <th class="text-left px-4 py-3 font-semibold text-base">
                {opB.name}
                {winner === 'B' && <span class="ml-2 text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-normal">Winner</span>}
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr>
              <td class="px-4 py-3 text-gray-500 font-medium">Composite Score</td>
              <td class="px-4 py-3">
                {revA?.composite
                  ? <span class="font-bold text-lg text-ocean-700">{revA.composite}<span class="text-xs text-gray-400 font-normal">/5</span></span>
                  : <span class="text-gray-400">–</span>}
              </td>
              <td class="px-4 py-3">
                {revB?.composite
                  ? <span class="font-bold text-lg text-ocean-700">{revB.composite}<span class="text-xs text-gray-400 font-normal">/5</span></span>
                  : <span class="text-gray-400">–</span>}
              </td>
            </tr>
            <tr class="bg-gray-50/50">
              <td class="px-4 py-3 text-gray-500 font-medium">TripAdvisor</td>
              <td class="px-4 py-3">
                {revA?.platforms?.tripadvisor?.rating
                  ? <>{revA.platforms.tripadvisor.rating} <span class="text-yellow-500 text-xs">{stars(revA.platforms.tripadvisor.rating)}</span></>
                  : <span class="text-gray-400">–</span>}
              </td>
              <td class="px-4 py-3">
                {revB?.platforms?.tripadvisor?.rating
                  ? <>{revB.platforms.tripadvisor.rating} <span class="text-yellow-500 text-xs">{stars(revB.platforms.tripadvisor.rating)}</span></>
                  : <span class="text-gray-400">–</span>}
              </td>
            </tr>
            <tr>
              <td class="px-4 py-3 text-gray-500 font-medium">Google</td>
              <td class="px-4 py-3">
                {revA?.platforms?.google?.rating
                  ? <>{revA.platforms.google.rating} <span class="text-yellow-500 text-xs">{stars(revA.platforms.google.rating)}</span> <span class="text-xs text-gray-400">({revA.platforms.google.reviewCount?.toLocaleString()} reviews)</span></>
                  : <span class="text-gray-400">–</span>}
              </td>
              <td class="px-4 py-3">
                {revB?.platforms?.google?.rating
                  ? <>{revB.platforms.google.rating} <span class="text-yellow-500 text-xs">{stars(revB.platforms.google.rating)}</span> <span class="text-xs text-gray-400">({revB.platforms.google.reviewCount?.toLocaleString()} reviews)</span></>
                  : <span class="text-gray-400">–</span>}
              </td>
            </tr>
            <tr class="bg-gray-50/50">
              <td class="px-4 py-3 text-gray-500 font-medium">Starting Price</td>
              <td class="px-4 py-3 font-semibold">${opA.price_low}</td>
              <td class="px-4 py-3 font-semibold">${opB.price_low}</td>
            </tr>
            <tr>
              <td class="px-4 py-3 text-gray-500 font-medium">Price Range</td>
              <td class="px-4 py-3">${opA.price_low}–${opA.price_high}</td>
              <td class="px-4 py-3">${opB.price_low}–${opB.price_high}</td>
            </tr>
            <tr class="bg-gray-50/50">
              <td class="px-4 py-3 text-gray-500 font-medium">Islands</td>
              <td class="px-4 py-3">{opA.islands.join(', ')}</td>
              <td class="px-4 py-3">{opB.islands.join(', ')}</td>
            </tr>
            <tr>
              <td class="px-4 py-3 text-gray-500 font-medium">Book</td>
              <td class="px-4 py-3">
                <a href={opA.website} target="_blank" rel="noopener noreferrer"
                  class="text-ocean-600 font-semibold hover:underline text-sm">→ Book {opA.name}</a>
              </td>
              <td class="px-4 py-3">
                <a href={opB.website} target="_blank" rel="noopener noreferrer"
                  class="text-ocean-600 font-semibold hover:underline text-sm">→ Book {opB.name}</a>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- What Reviewers Say — side by side excerpts -->
    {(reviewsA.length > 0 || reviewsB.length > 0) && (
      <section class="mb-10">
        <h2 class="text-xl font-semibold mb-4">What Reviewers Say</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Operator A reviews -->
          <div>
            <h3 class="font-semibold text-sm text-gray-600 mb-3 uppercase tracking-wide">{opA.name}</h3>
            <div class="space-y-3">
              {reviewsA.map(r => (
                <div class="border border-gray-100 rounded-lg p-3 bg-gray-50/50">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs text-gray-400">{r.source}</span>
                    {r.rating && <span class="text-xs text-yellow-500">{stars(r.rating)}</span>}
                  </div>
                  <p class="text-xs text-gray-700 leading-relaxed">{r.text.slice(0, 180)}{r.text.length > 180 ? '…' : ''}</p>
                </div>
              ))}
              {reviewsA.length === 0 && <p class="text-sm text-gray-400">Reviews loading…</p>}
            </div>
          </div>
          <!-- Operator B reviews -->
          <div>
            <h3 class="font-semibold text-sm text-gray-600 mb-3 uppercase tracking-wide">{opB.name}</h3>
            <div class="space-y-3">
              {reviewsB.map(r => (
                <div class="border border-gray-100 rounded-lg p-3 bg-gray-50/50">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs text-gray-400">{r.source}</span>
                    {r.rating && <span class="text-xs text-yellow-500">{stars(r.rating)}</span>}
                  </div>
                  <p class="text-xs text-gray-700 leading-relaxed">{r.text.slice(0, 180)}{r.text.length > 180 ? '…' : ''}</p>
                </div>
              ))}
              {reviewsB.length === 0 && <p class="text-sm text-gray-400">Reviews loading…</p>}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Choose A/B If — decision-maker cards -->
    <section class="grid md:grid-cols-2 gap-6 mb-10">
      <div class={`rounded-xl border p-6 ${winner === 'A' ? 'border-green-200 bg-green-50' : 'border-gray-200 bg-gray-50'}`}>
        <h2 class="text-lg font-semibold mb-3">Choose {opA.name} If...</h2>
        <ul class="space-y-2 text-sm text-gray-700 mb-5">
          {winner === 'A' && revA?.composite != null && (
            <li class="flex gap-2"><span class="text-green-600 mt-0.5">✓</span><span>You want the higher-rated option ({revA.composite}/5 vs {revB?.composite ?? '–'}/5)</span></li>
          )}
          <li class="flex gap-2"><span class="text-green-600 mt-0.5">✓</span><span>Starting price of ${opA.price_low} fits your budget</span></li>
          <li class="flex gap-2"><span class="text-green-600 mt-0.5">✓</span><span>You're visiting {opA.islands.slice(0, 2).join(' or ')}</span></li>
        </ul>
        <a href={opA.website} target="_blank" rel="noopener noreferrer"
          class="block text-center bg-ocean-600 text-white px-4 py-2.5 rounded-lg text-sm font-semibold hover:bg-ocean-700 transition-colors">
          Book {opA.name} →
        </a>
      </div>
      <div class={`rounded-xl border p-6 ${winner === 'B' ? 'border-green-200 bg-green-50' : 'border-gray-200 bg-gray-50'}`}>
        <h2 class="text-lg font-semibold mb-3">Choose {opB.name} If...</h2>
        <ul class="space-y-2 text-sm text-gray-700 mb-5">
          {winner === 'B' && revB?.composite != null && (
            <li class="flex gap-2"><span class="text-green-600 mt-0.5">✓</span><span>You want the higher-rated option ({revB.composite}/5 vs {revA?.composite ?? '–'}/5)</span></li>
          )}
          <li class="flex gap-2"><span class="text-green-600 mt-0.5">✓</span><span>Starting price of ${opB.price_low} fits your budget</span></li>
          <li class="flex gap-2"><span class="text-green-600 mt-0.5">✓</span><span>You're visiting {opB.islands.slice(0, 2).join(' or ')}</span></li>
        </ul>
        <a href={opB.website} target="_blank" rel="noopener noreferrer"
          class="block text-center bg-ocean-600 text-white px-4 py-2.5 rounded-lg text-sm font-semibold hover:bg-ocean-700 transition-colors">
          Book {opB.name} →
        </a>
      </div>
    </section>

    <!-- Book CTAs for both — bidirectional -->
    <section class="grid md:grid-cols-2 gap-4 mb-10">
      <div class="border border-gray-200 rounded-xl p-5">
        <div class="flex items-center justify-between mb-1">
          <h3 class="font-semibold">{opA.name}</h3>
          {winner === 'A' && <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">Top Pick</span>}
        </div>
        <p class="text-sm text-gray-500 mb-1">From ${opA.price_low} · {opA.islands.join(', ')}</p>
        {revA?.composite && <p class="text-sm font-semibold text-ocean-700 mb-3">{revA.composite}/5 composite</p>}
        <a href={`/operators/${toSlug(opA.name)}/`}
          class="block text-center border border-ocean-400 text-ocean-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-ocean-50 transition-colors mb-2">
          Read Full Review
        </a>
        <a href={opA.website} target="_blank" rel="noopener noreferrer"
          class="block text-center bg-ocean-600 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-ocean-700 transition-colors">
          Book {opA.name} →
        </a>
      </div>
      <div class="border border-gray-200 rounded-xl p-5">
        <div class="flex items-center justify-between mb-1">
          <h3 class="font-semibold">{opB.name}</h3>
          {winner === 'B' && <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">Top Pick</span>}
        </div>
        <p class="text-sm text-gray-500 mb-1">From ${opB.price_low} · {opB.islands.join(', ')}</p>
        {revB?.composite && <p class="text-sm font-semibold text-ocean-700 mb-3">{revB.composite}/5 composite</p>}
        <a href={`/operators/${toSlug(opB.name)}/`}
          class="block text-center border border-ocean-400 text-ocean-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-ocean-50 transition-colors mb-2">
          Read Full Review
        </a>
        <a href={opB.website} target="_blank" rel="noopener noreferrer"
          class="block text-center bg-ocean-600 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-ocean-700 transition-colors">
          Book {opB.name} →
        </a>
      </div>
    </section>

    <!-- Related comparisons (internal linking) -->
    {(() => {
      const related = operators.filter(op =>
        op.id !== opA.id && op.id !== opB.id &&
        op.activity === opA.activity &&
        op.islands.some(i => opA.islands.includes(i) || opB.islands.includes(i))
      ).slice(0, 4);
      return related.length > 0 ? (
        <section>
          <h2 class="text-lg font-semibold mb-3">More {opA.activity} Comparisons</h2>
          <div class="flex flex-wrap gap-2">
            {related.map(op => (
              <a href={`/compare/${toSlug(opA.name)}-vs-${toSlug(op.name)}/`}
                class="text-sm border border-gray-200 rounded-full px-3 py-1 hover:border-ocean-400 hover:text-ocean-700 transition-colors">
                {opA.name} vs {op.name}
              </a>
            ))}
            <a href={`/best/${opA.activity.toLowerCase().replace(/\s+/g,'-')}-${sharedIsland.toLowerCase().replace(/\s+/g,'-')}/`}
              class="text-sm border border-ocean-200 text-ocean-700 rounded-full px-3 py-1 hover:bg-ocean-50 transition-colors">
              Best {opA.activity} in {sharedIsland} →
            </a>
          </div>
        </section>
      ) : null;
    })()}

  </div>
</Base>
